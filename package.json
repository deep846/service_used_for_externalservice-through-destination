{
  "name": "services",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "express": "^4",
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "@sap/dev-cap-tools": "^1.31.0"
  },
  "scripts": {
    "start": "cds-serve"
  },
  "private": true,
  "cds": {
    "server": {
      "index": true
    },
    "requires": {
      "auth": {
        "kind": "dummy"
      },
      "[production]": {
        "db": "hana"
      },
      "empmanagement": {
        "kind": "odata",
        "model": "srv/external/empmanagement",
        "credentials": {
          "destination": "empmanagementsrvdest"
        }
      }
    }
  }
}
